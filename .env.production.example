# Production environment for Cloud Run deployments.
# In actual deployment, these come from Google Secret Manager (mounted as env
# vars on the Cloud Run revision) for secrets, or --build-env-vars for the
# NEXT_PUBLIC_* vars that must be baked into the client bundle at build time.
#
# See docs/superpowers/plans/2026-04-18-gcp-deployment.md for the full setup.

# === Required at BUILD time (baked into client bundle by `next build`) ===
# These are NOT secrets. The anon key is meant to be public; RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://shgsuahugiiuyopwyxtp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<eyJ... — Supabase Settings > API > "anon public" key>

# === Required at RUNTIME (mount from Secret Manager) ===
# Used by server routes. Never exposed to the client.
OPENAI_API_KEY=<sk-proj-... — platform.openai.com>

# === Optional at runtime ===
# Service role bypasses RLS. Only needed for the guest-invite branch of the
# submit route and any future admin scripts. Leave empty if unused.
SUPABASE_SERVICE_ROLE_KEY=<eyJ... — Supabase Settings > API > "service_role" key>

# ElevenLabs — required for voice mode (M3 milestone).
ELEVENLABS_API_KEY=<sk_... — elevenlabs.io dashboard>

# === Set by Cloud Run automatically (do NOT set manually) ===
# PORT=8080
# K_REVISION=<auto>
# K_SERVICE=survai
